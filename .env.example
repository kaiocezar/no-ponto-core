# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-troque-isso-em-producao-gere-com-python-secrets
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=agendador
POSTGRES_USER=agendador
POSTGRES_PASSWORD=agendador_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ── CORS (domínios do frontend que podem chamar a API) ────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── AWS S3 (para uploads de imagens) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=agendador-dev
AWS_S3_REGION_NAME=us-east-1

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend URL (usado em links de email/WhatsApp) ───────────────────────────
FRONTEND_URL=http://localhost:5173
